COMMIT;

CREATE OR REPLACE PROCEDURE total_marks(
    sid NUMBER
)
IS
    s1 NUMBER;
    s2 NUMBER;
    s3 NUMBER;
    total NUMBER;
BEGIN

    SELECT subject1, subject2, subject3
    INTO s1, s2, s3
    FROM student3
    WHERE student_id = sid;

    total := s1 + s2 + s3;

    DBMS_OUTPUT.PUT_LINE('Total Marks = ' || total);

END;
/

BEGIN
    total_marks(1);
END;
/

