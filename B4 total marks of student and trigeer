CREATE TABLE library_audit2 (
    book_id NUMBER(5),
    book_name VARCHAR2(50),
    author VARCHAR2(50),
    price NUMBER(8,2),
    action_type VARCHAR2(20),
    action_date DATE
);

CREATE OR REPLACE TRIGGER trg_library2
BEFORE UPDATE OR DELETE
ON library2
FOR EACH ROW

BEGIN

    IF UPDATING THEN

        INSERT INTO library_audit2
        VALUES (
            :OLD.book_id,
            :OLD.book_name,
            :OLD.author,
            :OLD.price,
            'UPDATE',
            SYSDATE
        );

    ELSIF DELETING THEN

        INSERT INTO library_audit2
        VALUES (
            :OLD.book_id,
            :OLD.book_name,
            :OLD.author,
            :OLD.price,
            'DELETE',
            SYSDATE
        );

    END IF;

END;
/


UPDATE library2
SET price = 800
WHERE book_id = 1;

DELETE FROM library2
WHERE book_id = 2;

COMMIT;

